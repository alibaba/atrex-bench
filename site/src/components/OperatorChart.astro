---
import operatorData from '../data/operators.json';
const { operators } = operatorData;
const sorted = [...operators].sort((a: any, b: any) => b.importance - a.importance);
const chartData = {
  labels: sorted.map((o: any) => o.name),
  values: sorted.map((o: any) => (o.importance * 100)),
  dtypes: sorted.map((o: any) => o.dtype),
};
---

<div class="page-section">
  <div class="page-container">
    <h2 class="section-heading" data-i18n="operators.chart.title">Operator Importance Distribution</h2>
    <p class="text-sm text-gray-500 mb-6" data-i18n="operators.chart.subtitle">
      Importance score reflects trace-derived GPU time share across production workloads
    </p>
    <div class="card p-4">
      <div style="height: 650px; position: relative;">
        <canvas id="importance-chart" data-chart={JSON.stringify(chartData)}></canvas>
      </div>
    </div>
  </div>
</div>

<script>
  import { Chart, BarController, BarElement, CategoryScale, LinearScale, Tooltip } from 'chart.js';
  Chart.register(BarController, BarElement, CategoryScale, LinearScale, Tooltip);

  const canvas = document.getElementById('importance-chart') as HTMLCanvasElement | null;
  if (canvas) {
    const data = JSON.parse(canvas.dataset.chart || '{}');

    const dtypeColors: Record<string, string> = {
      'bf16': 'rgba(59, 130, 246, 0.7)',
      'fp16': 'rgba(6, 182, 212, 0.7)',
      'fp8_e4m3': 'rgba(168, 85, 247, 0.7)',
      'fp32': 'rgba(245, 158, 11, 0.7)',
      'int32': 'rgba(156, 163, 175, 0.7)',
    };
    const borderColors: Record<string, string> = {
      'bf16': 'rgba(59, 130, 246, 1)',
      'fp16': 'rgba(6, 182, 212, 1)',
      'fp8_e4m3': 'rgba(168, 85, 247, 1)',
      'fp32': 'rgba(245, 158, 11, 1)',
      'int32': 'rgba(156, 163, 175, 1)',
    };

    new Chart(canvas, {
      type: 'bar',
      data: {
        labels: data.labels,
        datasets: [{
          data: data.values,
          backgroundColor: data.dtypes.map((d: string) => dtypeColors[d] || 'rgba(156, 163, 175, 0.7)'),
          borderColor: data.dtypes.map((d: string) => borderColors[d] || 'rgba(156, 163, 175, 1)'),
          borderWidth: 1,
          borderRadius: 3,
        }],
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (item) => `${item.parsed.x.toFixed(2)}% GPU time`,
              afterLabel: (item) => `dtype: ${data.dtypes[item.dataIndex]}`,
            },
            backgroundColor: 'rgb(17, 24, 39)',
            titleColor: 'rgb(255, 255, 255)',
            bodyColor: 'rgb(156, 163, 175)',
            borderColor: 'rgb(55, 65, 81)',
            borderWidth: 1,
          },
        },
        scales: {
          x: {
            title: { display: true, text: 'Importance Score (%)', color: '#6b7280' },
            grid: { color: 'rgba(55, 65, 81, 0.5)' },
            ticks: { color: '#9ca3af', callback: (v) => v + '%' },
          },
          y: {
            grid: { display: false },
            ticks: { color: '#d1d5db', font: { family: 'ui-monospace, monospace', size: 11 } },
          },
        },
      },
    });
  }
</script>
